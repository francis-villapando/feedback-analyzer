{
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "Feedback Analyzer",
  "description": "AI-Powered Feedback Analyzer for Enhancing Teaching Strategies in Digital Classrooms.",
  "icons": {
    "32": "icon32.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://meet.jit.si/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon32.png"
      ],
      "matches": [
        "https://meet.jit.si/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://meet.jit.si/*"
      ],
      "js": [
        "content.js",
        "ui.js"
      ],
      "css": [
        "popup.css"
      ],
      "run_at": "document_idle"
    }
  ]
}